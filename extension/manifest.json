{
  "manifest_version": 3,
  "name": "Skillman for Claude",
  "version": "1.0.0",
  "description": "Browse and install Claude skills directly from your browser — no manual uploads.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/icon16.png",
      "32":  "assets/icon32.png",
      "48":  "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/injector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "assets/icon16.png",
    "32":  "assets/icon32.png",
    "48":  "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
